<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#D10B0B0B"
                android:startColor="#E5161616" />
            <stroke
                android:width="1dp"
                android:color="@color/glass_edge" />
            <corners
                android:topLeftRadius="30dp"
                android:topRightRadius="30dp" />
        </shape>
    </item>
    <item
        android:bottom="1dp"
        android:left="1dp"
        android:right="1dp"
        android:top="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#05FFFFFF"
                android:startColor="@color/glass_glow" />
            <corners
                android:topLeftRadius="29dp"
                android:topRightRadius="29dp" />
        </shape>
    </item>
</layer-list>
