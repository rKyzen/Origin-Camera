<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="@color/glass_dark_soft"
                android:startColor="#D0171717" />
            <stroke
                android:width="1dp"
                android:color="@color/glass_edge" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <item
        android:bottom="1dp"
        android:left="1dp"
        android:right="1dp"
        android:top="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#03FFFFFF"
                android:startColor="@color/glass_glow" />
            <corners android:radius="17dp" />
        </shape>
    </item>
</layer-list>
