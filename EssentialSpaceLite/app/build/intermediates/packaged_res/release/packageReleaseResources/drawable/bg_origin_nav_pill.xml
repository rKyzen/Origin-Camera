<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="@color/glass_surface"
                android:startColor="@color/glass_surface_strong" />
            <stroke
                android:width="1.5dp"
                android:color="#66FFFFFF" />
            <corners android:radius="30dp" />
        </shape>
    </item>
    <item
        android:left="1dp"
        android:right="1dp"
        android:top="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#10FFFFFF" />
            <corners android:radius="29dp" />
        </shape>
    </item>
</layer-list>
