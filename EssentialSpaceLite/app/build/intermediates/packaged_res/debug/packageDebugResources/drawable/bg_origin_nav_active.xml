<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#E0101010"
                android:startColor="#F0181818" />
            <stroke
                android:width="1dp"
                android:color="@color/glass_edge" />
            <corners android:radius="22dp" />
        </shape>
    </item>
    <item
        android:left="1dp"
        android:right="1dp"
        android:top="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#0DFFFFFF" />
            <corners android:radius="21dp" />
        </shape>
    </item>
</layer-list>
