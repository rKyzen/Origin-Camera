<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="0dp"
    android:layout_height="156dp"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/glass_surface_strong"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/glass_edge"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <TextView
            android:id="@+id/card_kind"
            android:layout_width="wrap_content"
            android:layout_height="24dp"
            android:background="@drawable/bg_badge_chip"
            android:fontFamily="monospace"
            android:gravity="center"
            android:letterSpacing="0.08"
            android:minWidth="48dp"
            android:paddingHorizontal="10dp"
            android:text="@string/card_kind_note"
            android:textColor="@color/text_secondary"
            android:textSize="9sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/card_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:fontFamily="sans-serif-light"
            android:lineSpacingMultiplier="1.1"
            android:maxLines="3"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            app:layout_constraintEnd_toStartOf="@id/card_preview"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/card_kind"
            app:layout_goneMarginEnd="0dp" />

        <TextView
            android:id="@+id/card_reminder"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="monospace"
            android:maxLines="1"
            android:textColor="@color/accent_yellow"
            android:textSize="10sp"
            app:layout_constraintBottom_toTopOf="@id/card_time_group"
            app:layout_constraintEnd_toStartOf="@id/card_preview"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/card_text"
            app:layout_goneMarginEnd="0dp" />

        <ImageView
            android:id="@+id/card_preview"
            android:layout_width="84dp"
            android:layout_height="108dp"
            android:adjustViewBounds="true"
            android:background="@drawable/bg_thumbnail_placeholder"
            android:clipToOutline="true"
            android:outlineProvider="background"
            android:scaleType="centerCrop"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/card_time_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_waveform_origin"
                android:tint="@color/text_tertiary" />

            <TextView
                android:id="@+id/card_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:fontFamily="monospace"
                android:textColor="@color/text_tertiary"
                android:textSize="11sp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/card_voice"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_waveform_origin"
            android:tint="@color/text_primary"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
