<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="34dp"
        android:paddingEnd="20dp"
        android:paddingBottom="28dp">

        <TextView
            android:id="@+id/disclosure_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/ndot_47_inspired_by_nothing"
            android:letterSpacing="0.06"
            android:text="@string/disclosure_title"
            android:textColor="@color/text_primary"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/disclosure_heading"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:fontFamily="serif"
            android:lineSpacingMultiplier="1.08"
            android:text="@string/disclosure_heading"
            android:textColor="@color/text_primary"
            android:textSize="28sp" />

        <TextView
            android:id="@+id/disclosure_subheading"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:fontFamily="sans-serif-light"
            android:lineSpacingMultiplier="1.16"
            android:text="@string/disclosure_intro_body"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/setup_step_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_settings_row"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_chip"
                android:fontFamily="monospace"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:text="@string/disclosure_step_1"
                android:textColor="@color/text_secondary"
                android:textSize="9sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/ndot_47_inspired_by_nothing"
                android:text="@string/disclosure_reason_title"
                android:textColor="@color/text_primary"
                android:textSize="12sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="sans-serif-light"
                android:lineSpacingMultiplier="1.22"
                android:text="@string/disclosure_reason_body"
                android:textColor="@color/text_secondary"
                android:textSize="15sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="sans-serif-light"
                android:lineSpacingMultiplier="1.22"
                android:text="@string/disclosure_usage_body"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/setup_step_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_settings_row"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_chip"
                android:fontFamily="monospace"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:text="@string/disclosure_step_2"
                android:textColor="@color/text_secondary"
                android:textSize="9sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/ndot_47_inspired_by_nothing"
                android:text="@string/disclosure_permissions_title"
                android:textColor="@color/text_primary"
                android:textSize="12sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="sans-serif-light"
                android:text="@string/disclosure_permission_media"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="sans-serif-light"
                android:text="@string/disclosure_permission_mic"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="sans-serif-light"
                android:text="@string/disclosure_permission_notifications"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/setup_step_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_settings_row"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_chip"
                android:fontFamily="monospace"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:text="@string/disclosure_step_3"
                android:textColor="@color/text_secondary"
                android:textSize="9sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/ndot_47_inspired_by_nothing"
                android:text="@string/disclosure_limit_title"
                android:textColor="@color/text_primary"
                android:textSize="12sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="sans-serif-light"
                android:lineSpacingMultiplier="1.22"
                android:text="@string/disclosure_limit_body"
                android:textColor="@color/text_secondary"
                android:textSize="15sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="sans-serif-light"
                android:lineSpacingMultiplier="1.22"
                android:text="@string/disclosure_storage_body"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/setup_help_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:fontFamily="sans-serif-light"
            android:lineSpacingMultiplier="1.18"
            android:text="@string/disclosure_setup_hint"
            android:textColor="@color/text_tertiary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/btn_continue"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_save_button"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:letterSpacing="0.08"
            android:text="@string/disclosure_continue"
            android:textColor="@color/colorOnPrimary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/btn_permissions"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_settings_row"
            android:fontFamily="sans-serif-light"
            android:gravity="center"
            android:text="@string/disclosure_permissions_button"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/btn_later"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="10dp"
            android:background="@android:color/transparent"
            android:fontFamily="sans-serif-light"
            android:gravity="center"
            android:text="@string/disclosure_not_now"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />
    </LinearLayout>

</androidx.core.widget.NestedScrollView>
