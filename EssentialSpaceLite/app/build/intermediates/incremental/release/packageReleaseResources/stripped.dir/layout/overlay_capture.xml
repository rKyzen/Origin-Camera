<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/overlay_dim"
    android:clickable="true"
    android:focusable="true">

    <View
        android:id="@+id/flash_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/card_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_capture_card"
        android:orientation="vertical"
        android:paddingTop="14dp"
        android:paddingBottom="22dp"
        android:paddingHorizontal="18dp">

        <View
            android:layout_width="42dp"
            android:layout_height="3dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/bg_handle"
            android:alpha="0.55" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="top"
            android:orientation="horizontal">

            <FrameLayout
                android:id="@+id/thumbnail_container"
                android:layout_width="96dp"
                android:layout_height="132dp"
                android:background="@drawable/bg_thumbnail_placeholder">

                <View
                    android:id="@+id/thumbnail_placeholder"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_thumbnail_placeholder" />

                <TextView
                    android:id="@+id/screenshot_loading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:fontFamily="monospace"
                    android:text="..."
                    android:textColor="@color/text_placeholder"
                    android:textSize="16sp" />

                <ImageView
                    android:id="@+id/thumbnail_image"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_thumbnail_placeholder"
                    android:scaleType="centerCrop"
                    android:visibility="gone" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <EditText
                    android:id="@+id/text_note_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:fontFamily="sans-serif-light"
                    android:gravity="top"
                    android:hint="@string/overlay_note_hint"
                    android:inputType="textMultiLine|textCapSentences"
                    android:lineSpacingMultiplier="1.2"
                    android:maxLines="4"
                    android:minHeight="68dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_placeholder"
                    android:textCursorDrawable="@null"
                    android:textSize="17sp" />

                <TextView
                    android:id="@+id/overlay_caption"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="sans-serif-light"
                    android:lineSpacingMultiplier="1.1"
                    android:text="@string/overlay_caption"
                    android:textColor="@color/text_tertiary"
                    android:textSize="11sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="22dp"
                    android:layout_marginTop="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:id="@+id/recording_dot"
                        android:layout_width="6dp"
                        android:layout_height="6dp"
                        android:background="@drawable/bg_recording_dot"
                        android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/voice_waveform"
                        android:layout_width="54dp"
                        android:layout_height="18dp"
                        android:layout_marginStart="8dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:visibility="gone">

                        <View
                            android:id="@+id/voice_bar_1"
                            android:layout_width="4dp"
                            android:layout_height="8dp"
                            android:background="@color/accent_white" />

                        <View
                            android:id="@+id/voice_bar_2"
                            android:layout_width="4dp"
                            android:layout_height="12dp"
                            android:layout_marginStart="4dp"
                            android:background="@color/accent_white" />

                        <View
                            android:id="@+id/voice_bar_3"
                            android:layout_width="4dp"
                            android:layout_height="16dp"
                            android:layout_marginStart="4dp"
                            android:background="@color/accent_white" />

                        <View
                            android:id="@+id/voice_bar_4"
                            android:layout_width="4dp"
                            android:layout_height="12dp"
                            android:layout_marginStart="4dp"
                            android:background="@color/accent_white" />

                        <View
                            android:id="@+id/voice_bar_5"
                            android:layout_width="4dp"
                            android:layout_height="8dp"
                            android:layout_marginStart="4dp"
                            android:background="@color/accent_white" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/voice_timer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:fontFamily="monospace"
                        android:textColor="@color/text_tertiary"
                        android:textSize="12sp"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="28dp"
            android:background="@color/stroke" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btn_discard"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:contentDescription="Discard"
                android:src="@drawable/ic_close"
                android:tint="@color/text_tertiary" />

            <ImageView
                android:id="@+id/btn_voice"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="18dp"
                android:contentDescription="Voice note"
                android:src="@drawable/ic_mic"
                android:tint="@color/text_tertiary" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/btn_save"
                android:layout_width="wrap_content"
                android:layout_height="54dp"
                android:background="@drawable/bg_save_button"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:letterSpacing="0.16"
                android:paddingHorizontal="28dp"
                android:text="SAVE"
                android:textColor="@color/colorOnPrimary"
                android:textSize="15sp" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
