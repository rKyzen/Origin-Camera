<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/overlay_dim"
    android:clickable="true"
    android:focusable="true">

    <!-- Flash overlay: full-screen white flash on trigger -->
    <View
        android:id="@+id/flash_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF"
        android:visibility="gone"/>

    <!-- Bottom card — Nothing OS: dark surface, thin strokes, mono -->
    <LinearLayout
        android:id="@+id/card_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@drawable/bg_capture_card"
        android:paddingTop="12dp"
        android:paddingBottom="32dp"
        android:paddingHorizontal="20dp"
        android:elevation="0dp">

        <!-- Drag handle -->
        <View
            android:layout_width="32dp"
            android:layout_height="2dp"
            android:background="#3A3A3A"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="20dp"/>

        <!-- Screenshot area + text input row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="top">

            <!-- Thumbnail container: fixed phone-aspect ratio -->
            <FrameLayout
                android:id="@+id/thumbnail_container"
                android:layout_width="64dp"
                android:layout_height="114dp">

                <!-- Placeholder: crosshatch/grid hint -->
                <View
                    android:id="@+id/thumbnail_placeholder"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_thumbnail_placeholder"/>

                <!-- Loading indicator: pulsing dot while waiting for screenshot -->
                <TextView
                    android:id="@+id/screenshot_loading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="···"
                    android:textColor="#3A3A3A"
                    android:textSize="16sp"
                    android:fontFamily="monospace"
                    android:visibility="visible"/>

                <!-- Actual screenshot thumbnail -->
                <ImageView
                    android:id="@+id/thumbnail_image"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:clipToOutline="true"
                    android:outlineProvider="background"
                    android:background="@drawable/bg_thumbnail_placeholder"
                    android:visibility="gone"/>
            </FrameLayout>

            <!-- Text input -->
            <EditText
                android:id="@+id/text_note_input"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:background="@null"
                android:hint="Add a note…"
                android:textColorHint="#3C3C3C"
                android:textColor="#F0F0F0"
                android:textSize="14sp"
                android:fontFamily="sans-serif-light"
                android:letterSpacing="0.01"
                android:lineSpacingMultiplier="1.45"
                android:inputType="textMultiLine|textCapSentences"
                android:maxLines="6"
                android:gravity="top"
                android:minHeight="80dp"
                android:cursorVisible="true"
                android:textCursorDrawable="@null"/>
        </LinearLayout>

        <!-- Voice status row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="10dp">

            <!-- Recording pulse dot -->
            <View
                android:id="@+id/recording_dot"
                android:layout_width="5dp"
                android:layout_height="5dp"
                android:background="@drawable/bg_recording_dot"
                android:layout_marginEnd="7dp"
                android:visibility="gone"/>

            <!-- Waveform placeholder (animated via alpha) -->
            <View
                android:id="@+id/voice_waveform"
                android:layout_width="40dp"
                android:layout_height="2dp"
                android:background="#4AFFFFFF"
                android:visibility="gone"/>

            <!-- Timer / saved duration -->
            <TextView
                android:id="@+id/voice_timer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:textColor="#5A5A5A"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.04"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1E1E1E"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="14dp"/>

        <!-- Action row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Discard -->
            <ImageView
                android:id="@+id/btn_discard"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_close"
                android:tint="#4A4A4A"
                android:background="@null"
                android:contentDescription="Discard"
                android:padding="6dp"/>

            <!-- Voice record -->
            <ImageView
                android:id="@+id/btn_voice"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_mic"
                android:tint="#6A6A6A"
                android:background="@null"
                android:contentDescription="Voice note"
                android:layout_marginStart="8dp"
                android:padding="6dp"/>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>

            <!-- Save -->
            <TextView
                android:id="@+id/btn_save"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="SAVE"
                android:textColor="#0A0A0A"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.12"
                android:gravity="center"
                android:background="@drawable/bg_save_button"
                android:paddingHorizontal="24dp"
                android:includeFontPadding="false"/>
        </LinearLayout>

    </LinearLayout>
</FrameLayout>
