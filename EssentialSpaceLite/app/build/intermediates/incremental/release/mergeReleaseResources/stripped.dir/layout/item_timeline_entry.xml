<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="16dp">

    <!-- Date header (shown once per day) -->
    <TextView
        android:id="@+id/date_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_tertiary"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:letterSpacing="0.06"
        android:textAllCaps="true"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="8dp"
        android:layout_marginStart="4dp"
        android:visibility="gone"/>

    <!-- Entry card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/bg_card"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <!-- Screenshot thumbnail -->
            <ImageView
                android:id="@+id/thumbnail"
                android:layout_width="72dp"
                android:layout_height="128dp"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_thumbnail_placeholder"
                android:clipToOutline="true"
                android:outlineProvider="background"/>

            <!-- Content -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <!-- Time -->
                <TextView
                    android:id="@+id/entry_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_tertiary"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.04"/>

                <!-- Text note preview -->
                <TextView
                    android:id="@+id/text_note"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-light"
                    android:lineSpacingMultiplier="1.4"
                    android:maxLines="3"
                    android:ellipsize="end"
                    android:layout_marginTop="6dp"
                    android:visibility="gone"/>

                <!-- Voice badge -->
                <LinearLayout
                    android:id="@+id/voice_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_voice_badge"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp"
                    android:layout_marginTop="8dp"
                    android:visibility="gone">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="4dp"
                        android:background="@drawable/bg_dot"
                        android:layout_marginEnd="6dp"/>

                    <TextView
                        android:id="@+id/voice_duration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:fontFamily="monospace"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Right arrow -->
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_chevron_right"
                android:tint="@color/text_tertiary"
                android:layout_marginStart="8dp"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>
