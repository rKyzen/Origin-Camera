olor><color name="colorOnPrimary">#FFFFFF</color><color name="colorSecondary">#FFFFFF</color><color name="colorOnSecondary">#161A20</color><color name="colorSurface">#F8FAFC</color><color name="colorOnSurface">#14171C</color><color name="colorBackground">#F5F6F8</color><color name="colorOnBackground">#12151A</color><color name="colorError">#FF453A</color></file><file path="A:\dansh\EssentialSpaceLite\app\src\main\res\values\strings.xml" qualifiers=""><string name="app_name">Origin Space</string><string name="accessibility_service_label">Origin Space Capture</string><string name="accessibility_service_description">Detects simultaneous Volume Up + Down press to trigger an instant screenshot capture with notes and voice memos. No screen content is read until the capture is complete.</string><string name="disclosure_title">Accessibility Disclosure</string><string name="disclosure_heading">Origin Space needs Accessibility only for capture shortcuts.</string><string name="disclosure_reason_title">Why it is needed</string><string name="disclosure_reason_body">Origin Space uses Accessibility Service so it can detect your screenshot shortcut and start the post-capture flow only when you request it.</string><string name="disclosure_usage_title">How it is used</string><string name="disclosure_usage_body">The service listens for your hardware key gesture, triggers screenshot capture, and shows the note overlay after the screenshot is complete.</string><string name="disclosure_limit_title">What it does not do</string><string name="disclosure_limit_body">Origin Space does not use Accessibility to read your messages, inspect text you type, or monitor activity across apps.</string><string name="disclosure_storage_body">Screenshots, notes, and voice memos stay on your device unless you choose to share them.</string><string name="disclosure_continue">Continue to Accessibility Settings</string><string name="disclosure_not_now">Not now</string><string name="empty_state_title">Nothing c