<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.EssentialSpaceLite" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <style name="Theme.EssentialSpaceLite.Nothing" parent="Theme.EssentialSpaceLite">
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <style name="Theme.EssentialSpaceLite.Carbon" parent="Theme.EssentialSpaceLite">
        <item name="colorPrimary">@color/text_primary</item>
        <item name="colorOnPrimary">@color/bg_surface</item>
        <item name="android:statusBarColor">@color/bg_surface</item>
        <item name="android:navigationBarColor">@color/bg_surface</item>
    </style>

    <style name="Theme.EssentialSpaceLite.Glass" parent="Theme.EssentialSpaceLite">
        <item name="colorPrimary">@color/accent_yellow</item>
        <item name="colorOnPrimary">@color/bg_surface</item>
        <item name="android:statusBarColor">@color/bg_surface</item>
        <item name="android:navigationBarColor">@color/bg_surface</item>
    </style>
</resources>
