    <string name="app_name">Origin Space</string>
    <string name="accessibility_service_label">Origin Space Capture</string>
    <string name="accessibility_service_description">Detects simultaneous Volume Up + Down press to trigger an instant screenshot capture with notes and voice memos. No screen content is read until the capture is complete.</string>
    <string name="disclosure_title">Accessibility Disclosure</string>
    <string name="disclosure_heading">Origin Space needs Accessibility only for capture shortcuts.</string>
    <string name="disclosure_intro_body">This guide explains exactly what Origin Space needs before it can behave like a fast system-style capture space.</string>
    <string name="disclosure_step_1">STEP 1</string>
    <string name="disclosure_step_2">STEP 2</string>
    <string name="disclosure_step_3">STEP 3</string>
    <string name="disclosure_reason_title">Why it is needed</string>
    <string name="disclosure_reason_body">Origin Space uses Accessibility Service so it can detect your screenshot shortcut and start the post-capture flow only when you request it.</string>
    <string name="disclosure_usage_title">How it is used</string>
    <string name="disclosure_usage_body">The service listens for your hardware key gesture, triggers screenshot capture, and shows the note overlay after the screenshot is complete.</string>
    <string name="disclosure_permissions_title">Permissions you may see</string>
    <string name="disclosure_permission_media">Photos and media: used to read and display screenshots you create for the capture timeline.</string>
    <string name="disclosure_permission_mic">Microphone: used only when you choose to record a voice note after a capture.</string>
    <string name="disclosure_permission_notifications">Notifications: used for reminders so saved captures can call you back later.</string>
    <string name="disclosure_limit_title">What it does not do</string>
    <string name="disclosure_limit_body">Origin Space does not use Accessibility to read your messages, inspect text you type, or monitor activity across apps.</string>
    <string name="disclosure_storage_body">Screenshots, notes, and voice memos stay on your device unless you choose to share them.</string>
    <string name="disclosure_setup_hint">Recommended setup: enable Accessibility first, then review the app permissions page if you want to allow voice notes, screenshot access, and reminders.</string>
