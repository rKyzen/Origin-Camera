<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <View
        android:id="@+id/backdrop_blob_top"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="-64dp"
        android:layout_marginTop="108dp"
        android:alpha="0.72"
        android:background="@drawable/bg_glass_blob" />

    <View
        android:id="@+id/backdrop_blob_bottom"
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="-84dp"
        android:layout_marginBottom="118dp"
        android:alpha="0.48"
        android:background="@drawable/bg_glass_blob" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="110dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingTop="58dp"
            android:paddingEnd="18dp"
            android:paddingBottom="28dp">

            <TextView
                android:id="@+id/title_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/ndot_47_inspired_by_nothing"
                android:letterSpacing="0.02"
                android:text="@string/main_title"
                android:textColor="@color/text_primary"
                android:textSize="24sp" />

            <TextView
                android:id="@+id/subtitle_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="sans-serif-light"
                android:lineSpacingMultiplier="1.15"
                android:text="@string/main_subtitle"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <LinearLayout
                android:id="@+id/search_bar"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_origin_search_bar"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_search_origin"
                    android:tint="@color/text_primary" />

                <EditText
                    android:id="@+id/search_input"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@null"
                    android:fontFamily="sans-serif-light"
                    android:hint="@string/search_hint"
                    android:imeOptions="actionSearch"
                    android:inputType="text"
                    android:maxLines="1"
                    android:paddingStart="14dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_placeholder"
                    android:textSize="15sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/stats_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/stat_captures"
                    android:layout_width="0dp"
                    android:layout_height="58dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_stat_pill"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingHorizontal="10dp">

                    <TextView
                        android:id="@+id/stat_captures_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/ndot_47_inspired_by_nothing"
                        android:text="0"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.08"
                        android:text="@string/overview_stat_captures"
                        android:textColor="@color/text_tertiary"
                        android:textSize="9sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/stat_voice"
                    android:layout_width="0dp"
                    android:layout_height="58dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_stat_pill"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingHorizontal="10dp">

                    <TextView
                        android:id="@+id/stat_voice_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/ndot_47_inspired_by_nothing"
                        android:text="0"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.08"
                        android:text="@string/overview_stat_voice"
                        android:textColor="@color/text_tertiary"
                        android:textSize="9sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/stat_reminders"
                    android:layout_width="0dp"
                    android:layout_height="58dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_stat_pill"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingHorizontal="10dp">

                    <TextView
                        android:id="@+id/stat_reminders_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/ndot_47_inspired_by_nothing"
                        android:text="0"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.08"
                        android:text="@string/overview_stat_reminders"
                        android:textColor="@color/text_tertiary"
                        android:textSize="9sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/notes_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/recent_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.16"
                    android:text="@string/section_recent"
                    android:textColor="@color/text_tertiary"
                    android:textSize="12sp" />

                <LinearLayout
                    android:id="@+id/recent_rows"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical" />

                <TextView
                    android:id="@+id/today_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.16"
                    android:text="@string/section_today_essentials"
                    android:textColor="@color/text_tertiary"
                    android:textSize="12sp" />

                <LinearLayout
                    android:id="@+id/today_rows"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical" />

                <LinearLayout
                    android:id="@+id/empty_state"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="38dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingHorizontal="18dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/empty_state_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="serif"
                        android:text="@string/empty_state_title"
                        android:textColor="@color/text_primary"
                        android:textSize="22sp" />

                    <TextView
                        android:id="@+id/empty_state_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:fontFamily="sans-serif-light"
                        android:gravity="center"
                        android:lineSpacingMultiplier="1.35"
                        android:text="@string/empty_state_subtitle"
                        android:textColor="@color/text_tertiary"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/voice_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/voice_title_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:fontFamily="serif"
                    android:text="@string/voice_title"
                    android:textColor="@color/text_primary"
                    android:textSize="28sp" />

                <TextView
                    android:id="@+id/voice_subtitle_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="sans-serif-light"
                    android:lineSpacingMultiplier="1.12"
                    android:text="@string/voice_subtitle"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/voice_today_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.16"
                    android:text="@string/section_today"
                    android:textColor="@color/text_tertiary"
                    android:textSize="12sp" />

                <LinearLayout
                    android:id="@+id/voice_today_rows"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical" />

                <TextView
                    android:id="@+id/voice_yesterday_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.16"
                    android:text="@string/section_yesterday"
                    android:textColor="@color/text_tertiary"
                    android:textSize="12sp" />

                <LinearLayout
                    android:id="@+id/voice_yesterday_rows"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:gravity="center"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingBottom="18dp">

        <LinearLayout
            android:id="@+id/bottom_nav"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_origin_nav_pill"
            android:gravity="center_vertical"
            android:paddingHorizontal="8dp">

        <LinearLayout
            android:id="@+id/nav_notes"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_notes" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_voice"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_voice" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_search"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_search_origin" />
        </LinearLayout>
        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_settings_bottom"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_settings_gear"
            android:contentDescription="@string/settings_title"
            android:src="@drawable/ic_settings"
            android:tint="@color/text_primary" />
    </LinearLayout>

</FrameLayout>
