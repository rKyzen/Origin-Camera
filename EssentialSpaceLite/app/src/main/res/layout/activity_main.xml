<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="110dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingTop="58dp"
            android:paddingEnd="18dp"
            android:paddingBottom="28dp">

            <TextView
                android:id="@+id/title_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="serif"
                android:text="@string/main_title"
                android:textColor="@color/text_primary"
                android:textSize="28sp" />

            <LinearLayout
                android:id="@+id/search_bar"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="28dp"
                android:background="@drawable/bg_origin_search_bar"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_search_origin"
                    android:tint="@color/text_primary" />

                <EditText
                    android:id="@+id/search_input"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@null"
                    android:fontFamily="sans-serif-light"
                    android:hint="@string/search_hint"
                    android:imeOptions="actionSearch"
                    android:inputType="text"
                    android:maxLines="1"
                    android:paddingStart="14dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_placeholder"
                    android:textSize="15sp" />

                <ImageView
                    android:id="@+id/btn_settings"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@string/settings_title"
                    android:src="@drawable/ic_filter_origin"
                    android:tint="@color/text_primary" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/notes_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/recent_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.16"
                    android:text="@string/section_recent"
                    android:textColor="@color/text_tertiary"
                    android:textSize="12sp" />

                <LinearLayout
                    android:id="@+id/recent_rows"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical" />

                <TextView
                    android:id="@+id/today_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.16"
                    android:text="@string/section_today_essentials"
                    android:textColor="@color/text_tertiary"
                    android:textSize="12sp" />

                <LinearLayout
                    android:id="@+id/today_rows"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical" />

                <LinearLayout
                    android:id="@+id/empty_state"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="38dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingHorizontal="18dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/empty_state_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="serif"
                        android:text="@string/empty_state_title"
                        android:textColor="@color/text_primary"
                        android:textSize="22sp" />

                    <TextView
                        android:id="@+id/empty_state_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:fontFamily="sans-serif-light"
                        android:gravity="center"
                        android:lineSpacingMultiplier="1.35"
                        android:text="@string/empty_state_subtitle"
                        android:textColor="@color/text_tertiary"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/voice_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/voice_title_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:fontFamily="serif"
                    android:text="@string/voice_title"
                    android:textColor="@color/text_primary"
                    android:textSize="28sp" />

                <TextView
                    android:id="@+id/voice_today_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.16"
                    android:text="@string/section_today"
                    android:textColor="@color/text_tertiary"
                    android:textSize="12sp" />

                <LinearLayout
                    android:id="@+id/voice_today_rows"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical" />

                <TextView
                    android:id="@+id/voice_yesterday_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.16"
                    android:text="@string/section_yesterday"
                    android:textColor="@color/text_tertiary"
                    android:textSize="12sp" />

                <LinearLayout
                    android:id="@+id/voice_yesterday_rows"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="18dp"
        android:background="@drawable/bg_origin_nav_pill"
        android:gravity="center_vertical"
        android:paddingHorizontal="10dp">

        <LinearLayout
            android:id="@+id/nav_notes"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:background="@drawable/bg_origin_nav_active"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_nav_notes" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_voice"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_origin_mark" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_search"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_search_origin" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
