<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#CC140D0D"
                android:startColor="#D51B1111" />
            <stroke
                android:width="1dp"
                android:color="#4DFF3B30" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <item
        android:bottom="1dp"
        android:left="1dp"
        android:right="1dp"
        android:top="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#08FF3B30" />
            <corners android:radius="17dp" />
        </shape>
    </item>
</layer-list>
