<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- ── HERO AREA (fills above shelf) ─────────────────────────────── -->
    <LinearLayout
        android:id="@+id/heroArea"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingBottom="280dp">

        <ImageView
            android:id="@+id/ivIcon"
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:src="@drawable/ic_glyph_ring"
            android:tint="@color/accent_white"
            android:alpha="0.92"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BETTER NOTHING"
            android:textColor="@color/accent_white"
            android:textSize="16sp"
            android:letterSpacing="0.28"
            android:fontFamily="sans-serif-light"
            android:layout_marginTop="14dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MUSIC VISUALIZER"
            android:textColor="@color/accent_white"
            android:textSize="16sp"
            android:letterSpacing="0.28"
            android:fontFamily="sans-serif-light"
            android:layout_marginTop="2dp"/>

        <!-- Active preset pill -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/presetInfoCard"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            app:cardBackgroundColor="#1AFFFFFF"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="#33FFFFFF"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvActivePresetName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/accent_white"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvActivePresetDescription"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Select a preset to begin"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:maxWidth="260dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Status row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="20dp">

            <View
                android:id="@+id/statusDot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/dot_inactive"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pick a preset and tap Start"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ── BOTTOM SHELF ──────────────────────────────────────────────── -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomShelf"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        app:cardBackgroundColor="@color/shelf_bg"
        app:cardCornerRadius="28dp"
        app:cardElevation="24dp"
        app:strokeColor="@color/shelf_stroke"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Tab bar -->
            <LinearLayout
                android:id="@+id/tabBar"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp">

                <TextView
                    android:id="@+id/tabPlay"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="▶  PLAY"
                    android:textColor="@color/accent_white"
                    android:textSize="11sp"
                    android:letterSpacing="0.15"
                    android:gravity="center"
                    android:background="@drawable/tab_selected_bg"/>

                <TextView
                    android:id="@+id/tabTune"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="⚙  TUNE"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:letterSpacing="0.15"
                    android:gravity="center"
                    android:layout_marginStart="4dp"
                    android:background="@android:color/transparent"/>

                <TextView
                    android:id="@+id/tabInfo"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="ℹ  INFO"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:letterSpacing="0.15"
                    android:gravity="center"
                    android:layout_marginStart="4dp"
                    android:background="@android:color/transparent"/>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/shelf_stroke"
                android:layout_marginTop="2dp"/>

            <!-- ── TAB 1: PLAY ─────────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/panelPlay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="24dp">

                <!-- Preset carousel -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PRESETS"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:letterSpacing="0.2"/>

                <HorizontalScrollView
                    android:id="@+id/presetScroll"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/presetCarousel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"/>
                </HorizontalScrollView>

                <!-- Start/Stop button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnToggle"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="START"
                    android:textColor="@color/bg_dark"
                    android:letterSpacing="0.2"
                    android:textSize="14sp"
                    android:layout_marginTop="14dp"
                    app:backgroundTint="@color/accent_white"
                    app:cornerRadius="26dp"/>
            </LinearLayout>

            <!-- ── TAB 2: TUNE ─────────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/panelTune"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="16dp"
                android:paddingBottom="24dp"
                android:visibility="gone">

                <!-- Latency -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="LATENCY"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:letterSpacing="0.2"/>
                    <TextView
                        android:id="@+id/tvLatencyValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 ms"
                        android:textColor="@color/accent_white"
                        android:textSize="11sp"/>
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seekLatency"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:max="250"
                    android:progressTint="@color/accent_white"
                    android:thumbTint="@color/accent_white"/>

                <!-- Gamma -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="18dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="LED GAMMA"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:letterSpacing="0.2"/>
                    <TextView
                        android:id="@+id/tvGammaValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1.00"
                        android:textColor="@color/accent_white"
                        android:textSize="11sp"/>
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seekGamma"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:max="260"
                    android:progressTint="@color/accent_white"
                    android:thumbTint="@color/accent_white"/>
            </LinearLayout>

            <!-- ── TAB 3: INFO ─────────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/panelInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="16dp"
                android:paddingBottom="24dp"
                android:visibility="gone">

                <!-- Device selection -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DEVICE"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:letterSpacing="0.2"/>

                <TextView
                    android:id="@+id/tvDeviceLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Detecting…"
                    android:textColor="@color/dot_active_color"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp"/>

                <Spinner
                    android:id="@+id/spinnerDevice"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:layout_marginTop="6dp"
                    android:backgroundTint="@color/accent_white"/>

                <!-- Permissions -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PERMISSIONS"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:letterSpacing="0.2"
                    android:layout_marginTop="18dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGrantPermissions"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:text="Grant Notification Permission"
                    android:textColor="@color/bg_dark"
                    android:textSize="12sp"
                    android:layout_marginTop="6dp"
                    app:backgroundTint="@color/accent_white"
                    app:cornerRadius="20dp"/>

                <!-- Credits divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/shelf_stroke"
                    android:layout_marginTop="18dp"/>

                <!-- Credits -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CREDITS"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:letterSpacing="0.2"
                    android:layout_marginTop="14dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Visualization engine"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:layout_marginTop="10dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Aleks Levet"
                    android:textColor="@color/accent_white"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="better-nothing-music-visualizer"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:layout_marginTop="1dp"/>

                <View
                    android:layout_width="40dp"
                    android:layout_height="1dp"
                    android:background="@color/shelf_stroke"
                    android:layout_marginTop="10dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Android app"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:layout_marginTop="10dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Shivank Dan  ·  rKyzen"
                    android:textColor="@color/accent_white"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Better Nothing Music Visualizer"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:layout_marginTop="1dp"/>

            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
