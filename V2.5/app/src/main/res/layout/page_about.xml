<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:scrollbars="none"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="About &amp; other"
            android:textColor="#F0F0F0"
            android:textSize="28sp"
            android:fontFamily="sans-serif-light"
            android:layout_marginTop="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Better Nothing Music Visualizer turns your Nothing Phone&#8217;s Glyph LEDs into a real-time music visualizer — reacting to every beat, bassline and frequency shift in your audio."
            android:textColor="#888888"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.6"
            android:layout_marginTop="20dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="The visualization engine is based on the open-source better-nothing-music-visualizer project. It performs a 60fps FFT analysis of your audio output, maps frequency bands to individual Glyph zones using logarithmically-spaced presets, and drives the Ketchum SDK to flash LEDs in sync with the music."
            android:textColor="#888888"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.6"
            android:layout_marginTop="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No audio is stored, transmitted, or recorded. The analysis happens entirely on-device, frame by frame, and is discarded immediately after each Glyph update."
            android:textColor="#888888"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.6"
            android:layout_marginTop="12dp"/>

        <!-- Divider -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#1E1E1E" android:layout_marginTop="28dp"/>

        <!-- Credits -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Credits"
            android:textColor="#CCCCCC"
            android:textSize="18sp"
            android:layout_marginTop="24dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Visualization engine"
            android:textColor="#555555"
            android:textSize="11sp"
            android:letterSpacing="0.08"
            android:layout_marginTop="16dp"/>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Aleks Levet"
            android:textColor="#F0F0F0"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="3dp"/>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="better-nothing-music-visualizer"
            android:textColor="#3A3A3A"
            android:textSize="12sp"
            android:layout_marginTop="2dp"/>

        <View android:layout_width="32dp" android:layout_height="1dp"
            android:background="#222222" android:layout_marginTop="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Android app"
            android:textColor="#555555"
            android:textSize="11sp"
            android:letterSpacing="0.08"
            android:layout_marginTop="16dp"/>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Shivank Dan · rKyzen"
            android:textColor="#F0F0F0"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="3dp"/>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Better Nothing Music Visualizer"
            android:textColor="#3A3A3A"
            android:textSize="12sp"
            android:layout_marginTop="2dp"/>

        <!-- Version -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#1E1E1E" android:layout_marginTop="28dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Version 2.0 — Glyph Matrix SDK"
            android:textColor="#333333"
            android:textSize="11sp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"/>

    </LinearLayout>
</ScrollView>
