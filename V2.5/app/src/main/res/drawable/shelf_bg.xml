<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base frosted glass fill — very subtle dark tint -->
    <item>
        <shape android:shape="rectangle">
            <corners
                android:topLeftRadius="28dp"
                android:topRightRadius="28dp"
                android:bottomLeftRadius="0dp"
                android:bottomRightRadius="0dp"/>
            <solid android:color="#D9090909"/>
        </shape>
    </item>

    <!-- Inner top glow — simulates light catching the glass edge -->
    <item android:top="0dp" android:left="0dp" android:right="0dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <corners
                android:topLeftRadius="28dp"
                android:topRightRadius="28dp"
                android:bottomLeftRadius="0dp"
                android:bottomRightRadius="0dp"/>
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#16FFFFFF"
                android:endColor="#00FFFFFF"/>
        </shape>
    </item>

    <!-- Border — hairline white stroke on top and sides only -->
    <item>
        <shape android:shape="rectangle">
            <corners
                android:topLeftRadius="28dp"
                android:topRightRadius="28dp"
                android:bottomLeftRadius="0dp"
                android:bottomRightRadius="0dp"/>
            <stroke android:width="1dp" android:color="#30FFFFFF"/>
            <solid android:color="#00000000"/>
        </shape>
    </item>

</layer-list>
