<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="140dp"
    android:height="140dp"
    android:viewportWidth="140"
    android:viewportHeight="140">

    <!-- Outer full circle -->
    <path
        android:pathData="M70,8 A62,62 0 1,1 69.99,8 Z"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="2"
        android:fillColor="#00000000"/>

    <!-- Inner circle (slightly transparent) -->
    <path
        android:pathData="M70,26 A44,44 0 1,1 69.99,26 Z"
        android:strokeColor="#AAFFFFFF"
        android:strokeWidth="1.5"
        android:fillColor="#00000000"/>

    <!-- Centre dot -->
    <path
        android:pathData="M70,64 A6,6 0 1,1 69.99,64 Z"
        android:fillColor="#FFFFFFFF"/>

    <!-- Top tick — sits on outer ring at 12 o'clock -->
    <path
        android:pathData="M70,8 L70,20"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"/>

    <!-- Right tick — sits on outer ring at 3 o'clock -->
    <path
        android:pathData="M132,70 L120,70"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:fillColor="#00000000"/>

</vector>
